---
import { SITE } from '@/lib/site';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  canonical = new URL(Astro.url.pathname, SITE.url).toString(),
  image = '/social-cover.svg',
} = Astro.props;

const pageTitle = title === SITE.title ? title : `${title} · ${SITE.title}`;
const imageUrl = new URL(image, SITE.url).toString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
<meta name="theme-color" content="#f7f5f2" />
<link rel="canonical" href={canonical} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="alternate" type="application/rss+xml" title={`${SITE.title} RSS`} href="/rss.xml" />
<title>{pageTitle}</title>

<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta property="og:locale" content="zh_CN" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<script is:inline>
  const storedTheme = localStorage.getItem('theme');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  document.documentElement.dataset.theme = storedTheme || (prefersDark ? 'dark' : 'light');
</script>
