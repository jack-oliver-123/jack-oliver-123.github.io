<button class="theme-toggle" type="button" aria-label="切换深浅色模式" data-theme-toggle>
  <span data-theme-label>跟随系统</span>
</button>

<script>
  type ThemeName = 'light' | 'dark';

  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]');
  const allLabels = document.querySelectorAll<HTMLElement>('[data-theme-label]');

  const labels: Record<ThemeName, string> = {
    light: '浅色',
    dark: '深色',
  };

  function isThemeName(theme: string | undefined): theme is ThemeName {
    return theme === 'light' || theme === 'dark';
  }

  function updateLabels(text: string) {
    allLabels.forEach((el) => { el.textContent = text; });
  }

  function applyTheme(theme: ThemeName) {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem('theme', theme);
    updateLabels(labels[theme]);
  }

  const currentTheme = document.documentElement.dataset.theme;
  updateLabels(isThemeName(currentTheme) ? labels[currentTheme] : '跟随系统');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const nextTheme: ThemeName = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      applyTheme(nextTheme);
    });
  });
</script>
