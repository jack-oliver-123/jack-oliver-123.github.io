---
import type { MarkdownHeading } from 'astro';
import type { BlogPost } from '@/lib/posts';
import { getAdjacentPosts, getAllPosts, getPostUrl } from '@/lib/posts';
import ArticleMeta from '@/components/ArticleMeta.astro';
import CodeBlockCopy from '@/components/CodeBlockCopy.astro';
import MermaidRender from '@/components/MermaidRender.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  post: BlogPost;
  headings: MarkdownHeading[];
}

const { post, headings } = Astro.props;
const posts = await getAllPosts();
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const hasToc = tocHeadings.length > 0;
const { previous, next } = getAdjacentPosts(posts, post.id);
---

<BaseLayout title={post.data.title} description={post.data.description} bodyClass="post-page">
  <article class="post-layout">
    <a class="back-link" href="/blog/">← 返回全部文章</a>

    <header class="post-hero">
      <aside class="post-hero__note">
        <span>文章</span>
        <span>{String(posts.findIndex((item) => item.id === post.id) + 1).padStart(2, '0')}</span>
      </aside>
      <div>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
        <ArticleMeta post={post} body={post.body} />
      </div>
    </header>

    <div class:list={["post-reading-grid", { "post-reading-grid--without-toc": !hasToc }]}>
      {hasToc && <TableOfContents headings={tocHeadings} />}
      <div>
        <div class="prose" data-code-copy-root>
          <slot />
        </div>
        <CodeBlockCopy />
        <MermaidRender />

        <nav class="post-neighbors" aria-label="相邻文章">
          {previous ? <a href={getPostUrl(previous)}><span>上一篇</span>{previous.data.title}</a> : <span></span>}
          {next ? <a href={getPostUrl(next)}><span>下一篇</span>{next.data.title}</a> : <span></span>}
        </nav>
      </div>
    </div>
  </article>
</BaseLayout>
